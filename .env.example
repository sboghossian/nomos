# Copy this file to .env and fill in your own values.
# NEVER commit .env — it's gitignored for a reason.

# OpenRouter key for LLM fact extraction.
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Optional: used as OpenRouter HTTP-Referer / X-Title headers
NOMOS_APP_NAME=Nomos Playground
NOMOS_APP_URL=https://nomos.dashable.dev

# Optional: proxy API port (default 4330)
NOMOS_API_PORT=4330
