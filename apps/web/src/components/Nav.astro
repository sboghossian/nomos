---
interface Props {
  current?: string;
}
const { current } = Astro.props;

const items = [
  { label: 'Home', href: '/' },
  { label: 'Playground', href: '/play' },
  { label: 'Docs', href: '/docs/getting-started' },
  { label: 'Architecture', href: '/architecture' },
  { label: 'Thesis', href: '/research/thesis' },
  { label: 'Prior art', href: '/research/prior-art' },
  { label: 'Benchmarks', href: '/research/benchmarks' },
  { label: 'Changelog', href: '/changelog' },
];
---

<header class="rule-bottom sticky top-0 bg-cream/95 backdrop-blur z-20">
  <div class="max-w-wide mx-auto px-6 md:px-10 py-4 flex items-center justify-between gap-6">
    <a href="/" class="no-underline flex items-baseline gap-2 shrink-0">
      <span class="font-serif text-2xl text-accent" style="font-weight:500">ν</span>
      <span class="font-serif text-xl tracking-tight" style="font-weight:500">Nomos</span>
      <span class="chip ml-3 hidden md:inline-flex">Experimental</span>
    </a>
    <nav class="flex items-center gap-4 md:gap-5 text-[13px] text-sub overflow-x-auto">
      {items.map((i) => (
        <a
          href={i.href}
          class={`no-underline whitespace-nowrap ${current === i.href ? 'text-ink font-medium' : 'hover:text-ink'}`}>
          {i.label}
        </a>
      ))}
      <a
        href="https://github.com/sboghossian/nomos"
        target="_blank"
        aria-label="View source on GitHub"
        class="no-underline shrink-0 chip chip-accent inline-flex items-center gap-1.5">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
        </svg>
        GitHub
      </a>
    </nav>
  </div>
</header>
