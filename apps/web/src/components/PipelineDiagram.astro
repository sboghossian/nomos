---
/**
 * Animated pipeline diagram for the landing page.
 * Shows: .nomos source → Lexer → Parser → Checker → Fact resolver → Evaluator → Verdict
 * A stream of 'packet' dots flows left-to-right across the connectors, looping.
 */
---

<figure class="my-12">
  <svg
    viewBox="0 0 1200 340"
    xmlns="http://www.w3.org/2000/svg"
    class="w-full max-w-5xl mx-auto"
    aria-label="Nomos compiler pipeline: source, lexer, parser, checker, fact resolver, evaluator, verdict"
  >
    <defs>
      <!-- subtle drop shadow under each node -->
      <filter id="shadow" x="-10%" y="-10%" width="120%" height="120%">
        <feDropShadow dx="0" dy="2" stdDeviation="4" flood-color="#2D5016" flood-opacity="0.12" />
      </filter>

      <!-- arrow marker -->
      <marker id="arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="10" markerHeight="10" orient="auto">
        <path d="M0,0 L10,5 L0,10 z" fill="#5A7D3A" opacity="0.6" />
      </marker>

      <!-- gradient used by the animated 'packet' along the line -->
      <radialGradient id="packet" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#2D5016" stop-opacity="1" />
        <stop offset="60%" stop-color="#5A7D3A" stop-opacity="0.8" />
        <stop offset="100%" stop-color="#5A7D3A" stop-opacity="0" />
      </radialGradient>
    </defs>

    <!-- ── Background ─────────────────────────────── -->
    <rect x="0" y="0" width="1200" height="340" fill="transparent" />

    <!-- ── Nodes ──────────────────────────────────── -->
    <!-- columns centered at x-positions, equally spaced -->

    <!-- .nomos source -->
    <g filter="url(#shadow)">
      <rect x="20" y="120" width="150" height="100" rx="3" fill="#FFFFFF" stroke="#E8E3D8" />
      <text x="95" y="158" text-anchor="middle" font-family="Fraunces, serif" font-weight="500" font-size="17" fill="#1A1A1A">.nomos</text>
      <text x="95" y="180" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="11" fill="#7A7A6E" letter-spacing="0.08em">SOURCE</text>
      <text x="95" y="202" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#4A4A4A">rules + facts + query</text>
    </g>

    <!-- Lexer + Parser (grouped) -->
    <g filter="url(#shadow)">
      <rect x="210" y="120" width="150" height="100" rx="3" fill="#FAF8F3" stroke="#E8E3D8" />
      <text x="285" y="158" text-anchor="middle" font-family="Fraunces, serif" font-weight="500" font-size="17" fill="#1A1A1A">Parse</text>
      <text x="285" y="180" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="11" fill="#7A7A6E" letter-spacing="0.08em">LEX + CST → AST</text>
      <text x="285" y="202" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#4A4A4A">@nomos/core</text>
    </g>

    <!-- Checker -->
    <g filter="url(#shadow)">
      <rect x="400" y="120" width="150" height="100" rx="3" fill="#FAF8F3" stroke="#E8E3D8" />
      <text x="475" y="158" text-anchor="middle" font-family="Fraunces, serif" font-weight="500" font-size="17" fill="#1A1A1A">Check</text>
      <text x="475" y="180" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="11" fill="#7A7A6E" letter-spacing="0.08em">SYMBOL TABLE</text>
      <text x="475" y="202" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#4A4A4A">refs + diagnostics</text>
    </g>

    <!-- Fact resolver (LLM — accent) -->
    <g filter="url(#shadow)">
      <rect x="590" y="110" width="170" height="120" rx="3" fill="#EEF1E8" stroke="#5A7D3A" stroke-opacity="0.4" />
      <text x="675" y="148" text-anchor="middle" font-family="Fraunces, serif" font-weight="500" font-size="17" fill="#2D5016">Fact resolver</text>
      <text x="675" y="170" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="11" fill="#2D5016" letter-spacing="0.08em">extract&lt;T&gt; · LLM</text>
      <text x="675" y="191" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#4A4A4A">typed + confidence</text>
      <!-- small async badge -->
      <g>
        <rect x="608" y="118" width="58" height="18" rx="2" fill="#2D5016" />
        <text x="637" y="130" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#FAF8F3" letter-spacing="0.08em">ASYNC</text>
      </g>
    </g>

    <!-- Evaluator + defeasibility -->
    <g filter="url(#shadow)">
      <rect x="800" y="120" width="170" height="100" rx="3" fill="#FAF8F3" stroke="#E8E3D8" />
      <text x="885" y="158" text-anchor="middle" font-family="Fraunces, serif" font-weight="500" font-size="17" fill="#1A1A1A">Evaluator</text>
      <text x="885" y="180" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="11" fill="#7A7A6E" letter-spacing="0.08em">RULE ENGINE</text>
      <text x="885" y="202" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#4A4A4A">priority → specialis</text>
    </g>

    <!-- Verdict (accent) -->
    <g filter="url(#shadow)">
      <rect x="1010" y="120" width="170" height="100" rx="3" fill="#2D5016" />
      <text x="1095" y="158" text-anchor="middle" font-family="Fraunces, serif" font-weight="500" font-size="17" fill="#FAF8F3">Verdict</text>
      <text x="1095" y="180" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="11" fill="#FAF8F3" letter-spacing="0.08em" opacity="0.7">+ PROOF TREE</text>
      <text x="1095" y="202" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#FAF8F3" opacity="0.6">authorities · facts · why</text>
    </g>

    <!-- ── Connectors ────────────────────────────── -->
    <!-- horizontal lines between node centers -->
    <line x1="170" y1="170" x2="210" y2="170" stroke="#5A7D3A" stroke-opacity="0.35" stroke-width="1.5" marker-end="url(#arrow)" />
    <line x1="360" y1="170" x2="400" y2="170" stroke="#5A7D3A" stroke-opacity="0.35" stroke-width="1.5" marker-end="url(#arrow)" />
    <line x1="550" y1="170" x2="590" y2="170" stroke="#5A7D3A" stroke-opacity="0.35" stroke-width="1.5" marker-end="url(#arrow)" />
    <line x1="760" y1="170" x2="800" y2="170" stroke="#5A7D3A" stroke-opacity="0.35" stroke-width="1.5" marker-end="url(#arrow)" />
    <line x1="970" y1="170" x2="1010" y2="170" stroke="#5A7D3A" stroke-opacity="0.35" stroke-width="1.5" marker-end="url(#arrow)" />

    <!-- ── Animated packets — one per segment, staggered loop ── -->
    <g>
      <circle r="5" fill="url(#packet)">
        <animateMotion dur="6s" repeatCount="indefinite" rotate="auto" begin="0s">
          <mpath href="#flow-path" />
        </animateMotion>
      </circle>
      <circle r="4" fill="url(#packet)" opacity="0.7">
        <animateMotion dur="6s" repeatCount="indefinite" rotate="auto" begin="1.5s">
          <mpath href="#flow-path" />
        </animateMotion>
      </circle>
      <circle r="4" fill="url(#packet)" opacity="0.5">
        <animateMotion dur="6s" repeatCount="indefinite" rotate="auto" begin="3s">
          <mpath href="#flow-path" />
        </animateMotion>
      </circle>
    </g>

    <!-- Hidden path the packets travel along — all the way across -->
    <path
      id="flow-path"
      d="M 170,170 L 1180,170"
      fill="none"
      stroke="none"
    />

    <!-- ── Captions ──────────────────────────────── -->
    <text x="600" y="48" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="12" fill="#7A7A6E" letter-spacing="0.14em">
      THE COMPILER PIPELINE
    </text>
    <text x="600" y="76" text-anchor="middle" font-family="Fraunces, serif" font-weight="500" font-size="24" fill="#1A1A1A">
      source → parse → check → resolve facts → evaluate → verdict
    </text>

    <!-- Side labels -->
    <text x="95" y="275" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#7A7A6E">human-written</text>
    <text x="475" y="275" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#7A7A6E">deterministic</text>
    <text x="675" y="275" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#2D5016">one LLM call per extract&lt;T&gt;</text>
    <text x="885" y="275" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#7A7A6E">deterministic again</text>
    <text x="1095" y="275" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="10" fill="#7A7A6E">auditable output</text>
  </svg>

  <figcaption class="text-center mt-4 text-[13px] text-mute max-w-2xl mx-auto">
    Probabilistic at the edges (the fact resolver). Deterministic in the
    middle (parse, check, evaluate). Every arrow you see carries a typed value.
  </figcaption>
</figure>
