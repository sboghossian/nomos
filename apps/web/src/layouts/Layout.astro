---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  /** OG image path; defaults to the Nomos social preview. */
  image?: string;
  /** Canonical URL override. */
  canonical?: string;
}

const {
  title = "Nomos — a programming language for legal reasoning",
  description = "Nomos is an open-source programming language for legal AI. Write typed rules with jurisdiction and validity dates. Extract facts from contracts with LLMs. Get verdicts with proof trees back to statutes. For legal reasoning agents, compliance engines, and auditable contract analysis.",
  image = "/og.png",
  canonical,
} = Astro.props;

const site = "https://nomos.dashable.dev";
const url = canonical ?? new URL(Astro.url.pathname, site).toString();
const absImage = image.startsWith("http") ? image : `${site}${image}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="author" content="Stephane Boghossian" />
    <meta
      name="keywords"
      content="legal AI, legal reasoning, legal AI agents, rules as code, programming language for law, legal-tech, contract analysis, LLM agents, AI compliance, defeasible logic, legal tech open source, Catala alternative, OpenFisca alternative, legal reasoning AI, extract clauses AI, legal document AI, contract understanding, compliance automation, typed LLM, proof tree, legal extraction, Anthropic Claude legal, OpenRouter, TypeScript legal, Apache 2.0"
    />

    <!-- Canonical -->
    <link rel="canonical" href={url} />

    <!-- Open Graph / Twitter -->
    <meta property="og:site_name" content="Nomos" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={absImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- JSON-LD: marks Nomos as a SoftwareApplication for rich search results. -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        name: "Nomos",
        applicationCategory: "DeveloperApplication",
        operatingSystem: "macOS, Linux, Windows",
        description:
          "An experimental programming language for legal reasoning — typed rules, defeasible logic, LLM-powered fact extraction, proof trees.",
        url: site,
        author: {
          "@type": "Person",
          name: "Stephane Boghossian",
          url: "https://github.com/sboghossian",
        },
        license: "https://www.apache.org/licenses/LICENSE-2.0",
        codeRepository: "https://github.com/sboghossian/nomos",
        programmingLanguage: "TypeScript",
        softwareVersion: "0.1.0",
      })}
    />

    <!-- Flip to JS-enhanced mode *before paint* so the reveal CSS kicks in.
         If this script doesn't run, content stays visible — no broken page. -->
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>

    <title>{title}</title>
  </head>
  <body>
    <slot />

    <!-- Universal scroll-reveal: any element with class="reveal" fades in. -->
    <script>
      const io = new IntersectionObserver(
        (entries, observer) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add("revealed");
              observer.unobserve(e.target);
            }
          }
        },
        { threshold: 0.08, rootMargin: "0px 0px -40px 0px" },
      );
      document.querySelectorAll(".reveal").forEach((el) => io.observe(el));

      // Safety net: if for any reason the observer misses an element
      // (slow frames, dynamic content), reveal everything still hidden
      // after 2 seconds.
      setTimeout(() => {
        document
          .querySelectorAll(".reveal:not(.revealed)")
          .forEach((el) => el.classList.add("revealed"));
      }, 2000);
    </script>
  </body>
</html>
