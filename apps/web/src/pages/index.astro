---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';

const nomosExample = `// A French non-compete clause, reasoned about as of 2026-04-18.

type Party {
  name: String
  role: "seller" | "buyer" | "employee" | "employer" | "consumer"
}

type NonCompete {
  duration: Duration
  scope: Geography
  compensation_pct: Float
}

rule non_compete_enforceable @ FR from 2016-08-10 {
  requires clause.duration <= 24.months
  requires clause.scope is reasonable
  requires clause.compensation_pct >= 0.30
  authority: code_du_travail.art(L1121-1)
           ∧ cass_soc(2002-07-10, "00-45135")
}

rule consumer_protection_override @ FR priority 100
  defeats non_compete_enforceable
  when party.role == "consumer" {
  authority: code_conso.art(L212-1)
}

// LLM bridge — typed, verified, auditable.
fact parties: List<Party> = extract<Party>(contract.pdf)
  using llm(claude-opus-4-7)
  verified_by human if confidence < 0.95

fact clause: NonCompete = extract<NonCompete>(contract.pdf, section: "non-compete")
  using llm(claude-opus-4-7)

query non_compete_enforceable(clause, parties[0]) as of 2026-04-18
`;

const priorArt = [
  { name: 'Catala', org: 'Inria', contribution: 'Default logic for legislation, lawyer-readable syntax' },
  { name: 'OpenFisca', org: 'France', contribution: 'Proof that rules-as-code runs at government scale' },
  { name: 'Blawx', org: 'Lexpedite', contribution: 'Explanation generation over s(CASP)' },
  { name: 'Logical English', org: 'Kowalski / Imperial', contribution: 'Controlled natural language frontend' },
  { name: 'Kowalski et al. (1981)', org: 'British Nationality Act', contribution: 'The foundational encoding — CodeX Prize 2021' },
  { name: 'LegalRuleML', org: 'OASIS', contribution: 'Interop standard for legal rules' },
];

const stack = [
  { name: 'Eyecite', role: 'US citation resolver', href: 'https://github.com/freelawproject/eyecite' },
  { name: 'Concerto', role: 'Type system base', href: 'https://github.com/accordproject/concerto' },
  { name: 'Akoma Ntoso', role: 'Legislation import', href: 'http://www.akomantoso.org/' },
  { name: 'CUAD / MAUD / ACORD', role: 'Extraction benchmarks', href: 'https://www.atticusprojectai.org/' },
  { name: 'Restate', role: 'Durable execution', href: 'https://restate.dev' },
  { name: 'Docassemble', role: 'Interview export', href: 'https://docassemble.org/' },
];
---

<Layout>
  <Nav current="/" />

  <!-- Experimental banner -->
  <div class="bg-accent-bg border-b border-accent-soft/30">
    <div class="max-w-wide mx-auto px-6 md:px-10 py-2.5 flex items-center justify-between gap-4 text-[12px] md:text-[13px]">
      <span class="text-accent">
        <span class="font-mono uppercase tracking-[0.14em] mr-2">Experimental</span>
        <span class="hidden md:inline">Side project, built in public. Breaking changes expected. No warranty, no vendor, no company behind it.</span>
        <span class="md:hidden">Side project · built in public</span>
      </span>
      <a href="https://github.com/sboghossian/nomos" target="_blank" class="no-underline font-mono text-accent hover:underline whitespace-nowrap">
        github.com/sboghossian/nomos ↗
      </a>
    </div>
  </div>

  <!-- ─────────── Hero ─────────── -->
  <section class="max-w-wide mx-auto px-6 md:px-10 pt-20 md:pt-28 pb-24 md:pb-32">
    <div class="grid lg:grid-cols-[1.1fr_1fr] gap-x-16 gap-y-12 items-start">
      <!-- Left: tagline + CTA -->
      <div class="reveal">
        <div class="flex items-center gap-2 mb-8 flex-wrap">
          <span class="chip chip-accent">v0.1.0 · first public release</span>
          <span class="chip">Apache-2.0</span>
          <span class="chip">TypeScript</span>
        </div>

        <h1 class="max-w-[20ch]">
          A programming language for
          <em class="italic text-accent" style="font-feature-settings:'ss01'">legal reasoning.</em>
        </h1>

        <p class="mt-8 text-xl md:text-2xl max-w-prose text-sub font-serif" style="font-weight:400; line-height:1.45;">
          Rules carry jurisdiction, date, and authority. LLMs bridge prose to typed facts at the edges.
          A defeasibility engine resolves conflicts the way judges do. Every output is a proof tree
          back to statutes and cases.
        </p>

        <div class="mt-10 flex flex-wrap gap-3 items-center">
          <a
            href="/play"
            class="inline-block no-underline bg-ink text-cream px-5 py-3 text-[14px] font-medium hover:bg-accent transition-all hover:-translate-y-0.5 link-arrow">
            Try the playground
          </a>
          <a
            href="https://github.com/sboghossian/nomos"
            target="_blank"
            class="inline-block no-underline border border-ink px-5 py-3 text-[14px] font-medium hover:bg-ink hover:text-cream transition-all hover:-translate-y-0.5">
            Read the source ↗
          </a>
        </div>

        <p class="mt-6 text-[13px] text-mute">
          No install. No signup. Edit rules + facts in your browser.
        </p>
      </div>

      <!-- Right: live animated verdict demo -->
      <div class="reveal reveal-delayed">
        <div class="border border-rule bg-white shadow-[0_4px_20px_-8px_rgba(45,80,22,0.15)]">
          <!-- header -->
          <div class="flex items-center justify-between px-4 py-2.5 border-b border-rule bg-cream/50">
            <span class="font-mono text-[11px] uppercase tracking-[0.14em] text-mute">
              Live · non_compete_enforceable
            </span>
            <div class="flex items-center gap-1.5">
              <span id="live-dot" class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></span>
              <span class="font-mono text-[11px] text-accent">running</span>
            </div>
          </div>

          <!-- scenario label -->
          <div class="px-5 pt-5 pb-2">
            <span class="font-mono text-[11px] uppercase tracking-[0.14em] text-mute">
              Scenario
            </span>
            <p id="live-scenario" class="mt-1 font-serif text-lg transition-all duration-300 ease-out" style="font-weight:500">
              Employee · fair terms
            </p>
          </div>

          <!-- verdict -->
          <div class="px-5 py-4 border-y border-rule">
            <span class="font-mono text-[11px] uppercase tracking-[0.14em] text-mute">
              Verdict
            </span>
            <p id="live-verdict" class="mt-1 font-serif text-4xl md:text-5xl transition-all duration-300 ease-out" style="font-weight:500">
              —
            </p>
            <p id="live-rule" class="mt-2 text-[13px] text-sub font-mono transition-all duration-300 ease-out">
              winning rule: <span class="text-accent">—</span>
            </p>
          </div>

          <!-- proof chain -->
          <div class="px-5 py-4">
            <span class="font-mono text-[11px] uppercase tracking-[0.14em] text-mute">
              Proof chain
            </span>
            <ul id="live-proof" class="mt-2 space-y-1 text-[13px] font-mono text-ink">
              <li>&nbsp;</li>
            </ul>
          </div>

          <!-- tiebreaker footer -->
          <div id="live-tb" class="px-5 py-3 border-t border-rule bg-accent-bg/40 hidden">
            <p class="text-[12px] text-accent italic font-serif">
              <span class="not-italic font-mono font-normal text-[10px] uppercase tracking-[0.14em] text-mute mr-2">Tiebreaker</span>
              <span id="live-tb-text"></span>
            </p>
          </div>
        </div>

        <!-- scenario pager -->
        <div class="mt-4 flex items-center justify-center gap-2">
          <button data-scn="0" class="scn-btn w-2 h-2 rounded-full bg-ink transition-all" aria-label="Scenario 1"></button>
          <button data-scn="1" class="scn-btn w-2 h-2 rounded-full bg-rule transition-all" aria-label="Scenario 2"></button>
          <button data-scn="2" class="scn-btn w-2 h-2 rounded-full bg-rule transition-all" aria-label="Scenario 3"></button>
        </div>
      </div>
    </div>

    <!-- Etymology / definition block -->
    <div class="reveal mt-24 md:mt-32 border-t border-rule pt-8 grid md:grid-cols-[auto_1fr] gap-x-10 gap-y-3 max-w-3xl">
      <span class="font-mono text-[11px] uppercase tracking-[0.14em] text-mute pt-1">Noun · Greek</span>
      <div>
        <p class="font-serif text-ink text-xl leading-snug" style="font-weight:500">
          <span class="text-accent">νόμος</span> <span class="text-mute font-sans text-sm">/ˈnomos/</span>
        </p>
        <p class="mt-2 text-sub">
          Law, custom, rule. The binding norm a community recognizes as authoritative —
          weighted, contextual, contested. Used by Plato, Aristotle, and H.&thinsp;L.&thinsp;A.&thinsp;Hart to describe
          what a legal system actually <em>is</em>, before anyone wrote it down.
        </p>
      </div>
    </div>
  </section>

  <!-- ─────────── Thesis ─────────── -->
  <section id="thesis" class="rule-top bg-white reveal">
    <div class="max-w-wide mx-auto px-6 md:px-10 py-20 md:py-28 grid md:grid-cols-[220px_1fr] gap-10">
      <div>
        <span class="font-mono text-[11px] uppercase tracking-[0.14em] text-mute">§ 01 — Thesis</span>
        <h2 class="mt-4 font-serif">The premise.</h2>
      </div>
      <div class="max-w-prose space-y-6">
        <p class="text-ink text-lg font-serif leading-[1.55]" style="font-weight:400">
          Legal reasoning is already a computation. Statutes define predicates.
          Facts are inputs. Precedent is a priority ordering. Reforms are temporal updates.
          Judges have been running this computation for two thousand years.
          Logic programming knew it in the 1970s and couldn't finish the job because
          the world kept speaking in prose.
        </p>
        <p>
          LLMs changed that. Nomos puts the LLM at the edge — a typed bridge from prose
          to structured facts — and keeps the interior deterministic, defeasible, and
          auditable. You get the rigor of Catala, the pragmatism of OpenFisca, and the
          agent-native execution the rules-as-code field has always been missing.
        </p>
        <p>
          Not invented from scratch. Built as a layer on top of fifty years of work —
          Eyecite for citations, Concerto for types, Akoma Ntoso for legislation,
          Atticus for evaluation. Roughly fifteen percent new code, eighty-five percent
          standing on the shoulders of giants.
        </p>
      </div>
    </div>
  </section>

  <!-- ─────────── Language ─────────── -->
  <section id="language" class="rule-top reveal">
    <div class="max-w-wide mx-auto px-6 md:px-10 py-20 md:py-28">
      <div class="grid md:grid-cols-[220px_1fr] gap-10 mb-10">
        <div>
          <span class="font-mono text-[11px] uppercase tracking-[0.14em] text-mute">§ 02 — Language</span>
          <h2 class="mt-4 font-serif">A sketch.</h2>
        </div>
        <div class="max-w-prose">
          <p>
            A French non-compete clause, evaluated under the 2016 labour reform —
            with a consumer-protection rule that <em>defeats</em> enforceability
            when the employee is acting as a consumer. The LLM extracts
            structured facts from the PDF; the rule engine does the rest.
          </p>
        </div>
      </div>

      <div class="mt-6 border border-rule bg-white">
        <div class="flex items-center justify-between border-b border-rule px-5 py-2.5">
          <span class="font-mono text-[11px] uppercase tracking-[0.14em] text-mute">
            contract.nomos
          </span>
          <span class="font-mono text-[11px] text-accent">● ready</span>
        </div>
        <pre class="astro-code m-0 border-0"><code set:html={nomosExample.replace(/</g, '&lt;').replace(/>/g, '&gt;')}></code></pre>
      </div>

      <div class="mt-8 grid md:grid-cols-2 gap-6 max-w-prose">
        <div>
          <h4 class="font-serif text-lg mb-1.5" style="font-weight:500">Output — the value.</h4>
          <p class="text-sub text-[15px]">
            <code class="text-accent">false</code>. The clause is not enforceable;
            the consumer-protection rule defeats the labour-law rule by priority.
          </p>
        </div>
        <div>
          <h4 class="font-serif text-lg mb-1.5" style="font-weight:500">Output — the proof.</h4>
          <p class="text-sub text-[15px]">
            A tree: <code>L212-1</code> defeated <code>L1121-1</code>, which would have been satisfied
            by <code>Cass. soc. 2002-07-10 · no. 00-45135</code>. Every fact traced to its source.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─────────── Pillars ─────────── -->
  <section id="pillars" class="rule-top bg-white reveal">
    <div class="max-w-wide mx-auto px-6 md:px-10 py-20 md:py-28">
      <div class="grid md:grid-cols-[220px_1fr] gap-10 mb-16">
        <div>
          <span class="font-mono text-[11px] uppercase tracking-[0.14em] text-mute">§ 03 — Pillars</span>
          <h2 class="mt-4 font-serif">Four things nothing else has together.</h2>
        </div>
        <div class="max-w-prose">
          <p>
            Catala has default logic. OpenFisca has production adoption.
            LangGraph has agents. None have all four below.
          </p>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-x-12 gap-y-14">
        <!-- Pillar 1 -->
        <div>
          <div class="flex items-baseline gap-3 mb-3">
            <span class="font-mono text-[11px] uppercase tracking-[0.14em] text-accent">Pillar 1</span>
          </div>
          <h3 class="font-serif mb-3" style="font-weight:500">Typed LLM bridges.</h3>
          <p>
            <code>extract&lt;T&gt; using llm(...) verified_by human if confidence &lt; X</code> is a
            language primitive, not library plumbing. The model returns a typed value, or the
            compiler rejects it. Low-confidence extractions route to a human automatically.
          </p>
        </div>

        <!-- Pillar 2 -->
        <div>
          <div class="flex items-baseline gap-3 mb-3">
            <span class="font-mono text-[11px] uppercase tracking-[0.14em] text-accent">Pillar 2</span>
          </div>
          <h3 class="font-serif mb-3" style="font-weight:500">Time and jurisdiction, typed.</h3>
          <p>
            Rules declare <code>@ FR from 2016-08-10</code>. Queries run
            <code>as of 2015-01-01</code>. The compiler refuses to apply a
            post-reform rule to a pre-reform fact, or a French rule to a Lebanese party.
          </p>
        </div>

        <!-- Pillar 3 -->
        <div>
          <div class="flex items-baseline gap-3 mb-3">
            <span class="font-mono text-[11px] uppercase tracking-[0.14em] text-accent">Pillar 3</span>
          </div>
          <h3 class="font-serif mb-3" style="font-weight:500">Defeasibility, by design.</h3>
          <p>
            Legal rules contradict each other. Specific beats general, later beats earlier,
            higher court beats lower. Nomos resolves conflicts by priority, specificity, and
            recency — and tells you which rule defeated which, and why.
          </p>
        </div>

        <!-- Pillar 4 -->
        <div>
          <div class="flex items-baseline gap-3 mb-3">
            <span class="font-mono text-[11px] uppercase tracking-[0.14em] text-accent">Pillar 4</span>
          </div>
          <h3 class="font-serif mb-3" style="font-weight:500">Provenance, always.</h3>
          <p>
            Every value carries the authorities, facts, and rules that produced it.
            Ask <em>why</em> and you get a proof tree back to statute articles and case
            numbers — not a vibe, not a hallucination. Regulated industries have always
            needed this. Now they can have it.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─────────── Stack ─────────── -->
  <section id="stack" class="rule-top reveal">
    <div class="max-w-wide mx-auto px-6 md:px-10 py-20 md:py-28">
      <div class="grid md:grid-cols-[220px_1fr] gap-10 mb-12">
        <div>
          <span class="font-mono text-[11px] uppercase tracking-[0.14em] text-mute">§ 04 — Stack</span>
          <h2 class="mt-4 font-serif">A thin layer.</h2>
        </div>
        <div class="max-w-prose">
          <p>
            Nomos is roughly fifteen percent new code. The rest is permissively-licensed
            open source that has already been battle-tested at scale. We reuse, credit,
            and extend — never rewrite what works.
          </p>
        </div>
      </div>

      <div class="border-t border-rule">
        {stack.map((s) => (
          <a
            href={s.href}
            class="block border-b border-rule py-5 px-2 hover:bg-accent-bg transition-colors no-underline group">
            <div class="grid md:grid-cols-[1fr_2fr_auto] gap-4 items-baseline">
              <span class="font-serif text-lg text-ink" style="font-weight:500">{s.name}</span>
              <span class="text-sub text-[15px]">{s.role}</span>
              <span class="font-mono text-[11px] text-mute group-hover:text-accent">
                {new URL(s.href).hostname.replace(/^www\./, '')} ↗
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ─────────── Prior art ─────────── -->
  <section id="prior" class="rule-top bg-white reveal">
    <div class="max-w-wide mx-auto px-6 md:px-10 py-20 md:py-28">
      <div class="grid md:grid-cols-[220px_1fr] gap-10 mb-12">
        <div>
          <span class="font-mono text-[11px] uppercase tracking-[0.14em] text-mute">§ 05 — Prior art</span>
          <h2 class="mt-4 font-serif">Standing on shoulders.</h2>
        </div>
        <div class="max-w-prose">
          <p>
            The rules-as-code tradition is fifty years old. Nomos is not the first attempt.
            It is an attempt to combine the best of each into something a developer in 2026
            would actually use.
          </p>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-x-12 gap-y-8">
        {priorArt.map((p) => (
          <div class="border-l-2 border-accent-soft/40 pl-5 py-1">
            <div class="flex items-baseline gap-3 mb-1.5">
              <span class="font-serif text-lg" style="font-weight:500">{p.name}</span>
              <span class="font-mono text-[11px] uppercase tracking-[0.14em] text-mute">{p.org}</span>
            </div>
            <p class="text-sub text-[15px]">{p.contribution}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─────────── Closing call ─────────── -->
  <section class="rule-top reveal">
    <div class="max-w-wide mx-auto px-6 md:px-10 py-24 md:py-32 text-center">
      <h2 class="font-serif text-4xl md:text-5xl max-w-[28ch] mx-auto" style="font-weight:500">
        Code the law.
        <span class="text-accent italic">Audit the reasoning.</span>
      </h2>
      <p class="mt-6 max-w-prose mx-auto">
        A side project, shipped in the open. Six weekends to v0.1. No company,
        no roadmap committee — just a language, a compiler, and a web playground.
      </p>

      <div class="mt-10 flex flex-wrap gap-3 justify-center">
        <a
          href="https://github.com/sboghossian/nomos"
          class="inline-block no-underline bg-ink text-cream px-5 py-3 text-[14px] font-medium hover:bg-accent transition-colors link-arrow">
          Star on GitHub
        </a>
        <a
          href="#"
          class="inline-block no-underline border border-ink px-5 py-3 text-[14px] font-medium hover:bg-ink hover:text-cream transition-colors">
          Join Discord
        </a>
      </div>
    </div>
  </section>

  <!-- ─────────── Footer ─────────── -->
  <footer class="rule-top bg-white">
    <div class="max-w-wide mx-auto px-6 md:px-10 py-10 grid md:grid-cols-3 gap-8 text-[13px]">
      <div>
        <div class="flex items-baseline gap-2 mb-3">
          <span class="font-serif text-lg text-accent" style="font-weight:500">ν</span>
          <span class="font-serif text-lg" style="font-weight:500">Nomos</span>
        </div>
        <p class="text-mute max-w-[40ch]">
          A programming language for legal reasoning. Apache-2.0.
          Not affiliated with any law firm, vendor, or bar association.
        </p>
      </div>

      <div class="flex flex-col gap-2">
        <span class="font-mono text-[11px] uppercase tracking-[0.14em] text-mute mb-1">Project</span>
        <a href="https://github.com/sboghossian/nomos" class="no-underline text-sub hover:text-ink">GitHub</a>
        <a href="#" class="no-underline text-sub hover:text-ink">Docs</a>
        <a href="#" class="no-underline text-sub hover:text-ink">Playground</a>
        <a href="#" class="no-underline text-sub hover:text-ink">Changelog</a>
      </div>

      <div class="flex flex-col gap-2">
        <span class="font-mono text-[11px] uppercase tracking-[0.14em] text-mute mb-1">Credit where due</span>
        <a href="https://catala-lang.org/" class="no-underline text-sub hover:text-ink">Catala — Inria</a>
        <a href="https://openfisca.org/" class="no-underline text-sub hover:text-ink">OpenFisca</a>
        <a href="https://free.law/" class="no-underline text-sub hover:text-ink">Free Law Project</a>
        <a href="https://www.atticusprojectai.org/" class="no-underline text-sub hover:text-ink">Atticus Project</a>
      </div>
    </div>
    <div class="border-t border-rule">
      <div class="max-w-wide mx-auto px-6 md:px-10 py-5 flex items-center justify-between text-[12px] text-mute">
        <span>© 2026 · A side project by Stephane Boghossian.</span>
        <span class="font-mono">νόμος · nómos · nomos</span>
      </div>
    </div>
  </footer>
</Layout>

<!-- ───────────── Live verdict demo + scroll reveal ───────────── -->
<script>
  // Scenarios are hard-coded — they match the /play playground's presets.
  const scenarios = [
    {
      label: 'Employee · fair terms',
      verdict: 'ENFORCEABLE',
      verdictClass: 'text-accent',
      rule: 'non_compete_enforceable',
      proof: [
        ['✓', 'clause.duration <= 24', 'true'],
        ['✓', 'clause.scope is reasonable', 'true'],
        ['✓', 'clause.compensation_pct >= 0.30', 'true'],
      ],
      tiebreaker: null,
    },
    {
      label: 'Consumer role · override fires',
      verdict: 'NOT ENFORCEABLE',
      verdictClass: 'text-red-700',
      rule: 'consumer_protection_override',
      proof: [
        ['✓', 'non_compete_enforceable', 'satisfied'],
        ['✓', 'consumer_protection_override', 'satisfied'],
        ['⚖', 'defeated: non_compete_enforceable', ''],
      ],
      tiebreaker:
        'decided by priority — consumer_protection_override (100) beats non_compete_enforceable (0).',
    },
    {
      label: 'Underpaid (12%) · base rule fails',
      verdict: 'NOT ENFORCEABLE',
      verdictClass: 'text-red-700',
      rule: '— (no rule fired)',
      proof: [
        ['✓', 'clause.duration <= 24', 'true'],
        ['✓', 'clause.scope is reasonable', 'true'],
        ['✗', 'clause.compensation_pct >= 0.30', 'false'],
      ],
      tiebreaker: null,
    },
  ];

  const $ = (id: string) => document.getElementById(id);
  const scenarioEl = $('live-scenario');
  const verdictEl = $('live-verdict');
  const ruleEl = $('live-rule');
  const proofEl = $('live-proof');
  const tbEl = $('live-tb');
  const tbTextEl = $('live-tb-text');
  const dots = Array.from(
    document.querySelectorAll<HTMLButtonElement>('.scn-btn'),
  );

  let current = 0;
  let timer: number | undefined;
  let paused = false;

  function render(i: number) {
    const s = scenarios[i];
    if (!s) return;

    // subtle fade transition
    const box = [scenarioEl, verdictEl, ruleEl, proofEl];
    box.forEach((el) => el && (el.style.opacity = '0'));

    setTimeout(() => {
      if (scenarioEl) scenarioEl.textContent = s.label;
      if (verdictEl) {
        verdictEl.textContent = s.verdict;
        verdictEl.className =
          'mt-1 font-serif text-4xl md:text-5xl transition-all duration-300 ease-out ' +
          s.verdictClass;
      }
      if (ruleEl) {
        ruleEl.innerHTML =
          'winning rule: <span class="text-accent">' + s.rule + '</span>';
      }
      if (proofEl) {
        proofEl.innerHTML = s.proof
          .map(([icon, clause, value]) => {
            const color =
              icon === '✓'
                ? 'text-accent'
                : icon === '✗'
                  ? 'text-red-700'
                  : 'text-yellow-700';
            const val = value
              ? '<span class="text-mute"> → ' + value + '</span>'
              : '';
            return (
              '<li><span class="' +
              color +
              ' mr-2">' +
              icon +
              '</span>' +
              clause +
              val +
              '</li>'
            );
          })
          .join('');
      }
      if (s.tiebreaker && tbEl && tbTextEl) {
        tbEl.classList.remove('hidden');
        tbTextEl.textContent = s.tiebreaker;
      } else {
        tbEl?.classList.add('hidden');
      }
      box.forEach((el) => el && (el.style.opacity = '1'));
    }, 200);

    dots.forEach((d, j) => {
      d.className =
        'scn-btn w-2 h-2 rounded-full transition-all ' +
        (j === i ? 'bg-ink scale-125' : 'bg-rule');
    });
  }

  function next() {
    if (paused) return;
    current = (current + 1) % scenarios.length;
    render(current);
  }

  function schedule() {
    if (timer) window.clearTimeout(timer);
    timer = window.setTimeout(next, 3600);
  }

  function loop() {
    schedule();
  }

  // initial render
  render(0);

  // cycle
  setInterval(loop, 3600);

  // let users pin a scenario by clicking a dot (pauses auto-cycle)
  dots.forEach((d, i) => {
    d.addEventListener('click', () => {
      paused = true;
      current = i;
      render(i);
    });
  });

  // Scroll reveal is handled globally in Layout.astro.
</script>
