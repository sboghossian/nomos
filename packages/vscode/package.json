{
  "name": "nomos-vscode",
  "displayName": "Nomos",
  "description": "Syntax highlighting, diagnostics, and hovers for the Nomos legal-reasoning language.",
  "version": "0.0.1",
  "publisher": "sboghossian",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/sboghossian/nomos"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "activationEvents": [
    "onLanguage:nomos"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "nomos",
        "aliases": [
          "Nomos",
          "nomos"
        ],
        "extensions": [
          ".nomos"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "nomos",
        "scopeName": "source.nomos",
        "path": "./syntaxes/nomos.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Nomos",
      "properties": {
        "nomos.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces communication between VS Code and the Nomos language server."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "package": "vsce package"
  },
  "dependencies": {
    "@nomos/core": "0.0.1",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.6.3"
  }
}
